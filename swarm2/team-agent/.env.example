# Team Agent Configuration

# OpenAI API Key (required for LLM functionality)
OPENAI_API_KEY=your-api-key-here

# Optional: Override default model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Optional: Custom OpenAI base URL
# OPENAI_BASE_URL=https://api.openai.com/v1

# Flask Configuration
SECRET_KEY=dev-secret-key-change-in-production
FLASK_DEBUG=True

# ------------------------------------------------------------------
# Phase 2: Agent Discovery & Interoperability
# ------------------------------------------------------------------
# Public URL where this agent is reachable
AGENT_PUBLIC_URL=https://agent.example.com

# ------------------------------------------------------------------
# Phase 3: Ethereum Optimism L2 Integration
# ------------------------------------------------------------------
# Optimism RPC URL (e.g., Alchemy, Infura, or QuickNode)
OPTIMISM_RPC_URL=https://opt-goerli.g.alchemy.com/v2/YOUR-API-KEY

# Private Key for Agent Identity (must hold ETH/OP for gas)
AGENT_PRIVATE_KEY=0x...

# Smart Contract Addresses
WORKFLOW_CONDUCTOR_ADDRESS=0x...
CAPABILITY_MARKETPLACE_ADDRESS=0x...

# ------------------------------------------------------------------
# Phase 3: Decentralized Storage (IPFS)
# ------------------------------------------------------------------
# IPFS Gateway URL
IPFS_GATEWAY_URL=https://gateway.pinata.cloud/ipfs/

# Pinata API Keys (or other pinning service)
PINATA_API_KEY=your-pinata-api-key
PINATA_SECRET_API_KEY=your-pinata-secret-key
