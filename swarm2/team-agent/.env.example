# Team Agent Configuration

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Policy Engine
MIN_QUALITY_SCORE=70
COMPLIANCE_THRESHOLD=80

# Governance
REQUIRE_REVIEW_PASSED=true
REQUIRE_APPROVAL=true

# Recording & Signing
ENABLE_CRYPTOGRAPHIC_SIGNING=true
RECORD_RETENTION_DAYS=90

# Exports
EXPORT_SIEM=false
EXPORT_A2A=false
EXPORT_MCP=false
EXPORT_BLOCKCHAIN=false# This file is intentionally left blank.