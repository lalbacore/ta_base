<template>
  <div class="episode-detail-view">
    <div v-if="loading" class="loading">
      <div class="spinner"></div>
      <p>Loading episode...</p>
    </div>

    <div v-else-if="error" class="error-state">
      <h2>Error Loading Episode</h2>
      <p>{{ error }}</p>
      <button @click="$router.push('/episodes')" class="btn-back">← Back to Episodes</button>
    </div>

    <div v-else-if="episode" class="episode-content">
      <!-- Header -->
      <div class="episode-header">
        <div class="header-top">
          <button @click="$router.push('/episodes')" class="btn-back">← Back</button>
          <div class="header-actions">
            <button @click="loadEpisode" class="btn-icon" title="Refresh">🔄</button>
            <button v-if="episode.status === 'completed' && !episode.rating" 
                    @click="showRatingModal = true" 
                    class="btn-primary">
              Rate Episode
            </button>
          </div>
        </div>
        
        <div class="header-main">
          <h1>{{ episode.episode_id }}</h1>
          <span class="status-badge" :class="episode.status">{{ episode.status }}</span>
        </div>

        <div class="header-meta">
          <div class="meta-item">
            <span class="label">Mission:</span>
            <span class="value">{{ episode.mission_id }}</span>
          </div>
          <div class="meta-item">
            <span class="label">Created:</span>
            <span class="value">{{ formatDate(episode.created_at) }}</span>
          </div>
          <div class="meta-item" v-if="episode.completed_at">
            <span class="label">Duration:</span>
            <span class="value">{{ calculateDuration() }}</span>
          </div>
        </div>
      </div>

      <!-- Effectiveness Score -->
      <div v-if="episode.effectiveness_score > 0" class="effectiveness-section">
        <h2>Effectiveness Score</h2>
        <div class="score-display">
          <div class="score-circle" :class="getEffectivenessClass(episode.effectiveness_score)">
            <span class="score-value">{{ episode.effectiveness_score.toFixed(1) }}</span>
            <span class="score-label">%</span>
          </div>
          <div class="score-breakdown" v-if="episode.rating">
            <div class="breakdown-item">
              <span class="breakdown-label">Artifact Quality</span>
              <div class="breakdown-bar">
                <div class="bar-fill" :style="{ width: episode.rating.artifact_quality + '%' }"></div>
              </div>
              <span class="breakdown-value">{{ episode.rating.artifact_quality.toFixed(1) }}%</span>
            </div>
            <div class="breakdown-item">
              <span class="breakdown-label">Execution Efficiency</span>
              <div class="breakdown-bar">
                <div class="bar-fill" :style="{ width: episode.rating.execution_efficiency + '%' }"></div>
              </div>
              <span class="breakdown-value">{{ episode.rating.execution_efficiency.toFixed(1) }}%</span>
            </div>
            <div class="breakdown-item">
              <span class="breakdown-label">Path Optimality</span>
              <div class="breakdown-bar">
                <div class="bar-fill" :style="{ width: episode.rating.path_optimality + '%' }"></div>
              </div>
              <span class="breakdown-value">{{ episode.rating.path_optimality.toFixed(1) }}%</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Tabs -->
      <div class="tabs">
        <button 
          v-for="tab in tabs" 
          :key="tab.id"
          @click="activeTab = tab.id"
          class="tab"
          :class="{ active: activeTab === tab.id }"
        >
          {{ tab.label }}
          <span v-if="tab.count !== undefined" class="tab-count">{{ tab.count }}</span>
        </button>
      </div>

      <!-- Tab Content -->
      <div class="tab-content">
        <!-- Overview Tab -->
        <div v-if="activeTab === 'overview'" class="overview-tab">
          <div class="info-grid">
            <div class="info-card">
              <h3>Agents</h3>
              <div class="agent-list">
                <div v-for="agent in episode.agents" :key="agent.agent_id" class="agent-item">
                  <div class="agent-header">
                    <span class="agent-id">{{ agent.agent_id }}</span>
                    <span class="agent-role">{{ agent.role }}</span>
                  </div>
                  <div class="agent-stats">
                    <span>{{ agent.steps_executed }} steps</span>
                    <span>{{ agent.decisions_made }} decisions</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="info-card">
              <h3>Statistics</h3>
              <div class="stats-list">
                <div class="stat-row">
                  <span>Total Steps:</span>
                  <strong>{{ episode.execution_steps }}</strong>
                </div>
                <div class="stat-row">
                  <span>Decision Points:</span>
                  <strong>{{ episode.decision_points }}</strong>
                </div>
                <div class="stat-row">
                  <span>Artifacts:</span>
                  <strong>{{ episode.artifacts?.length || 0 }}</strong>
                </div>
                <div class="stat-row" v-if="deviations">
                  <span>Deviations:</span>
                  <strong :class="{ warning: deviations.deviated_steps > 0 }">
                    {{ deviations.deviated_steps }}
                  </strong>
                </div>
              </div>
            </div>

            <div class="info-card" v-if="chainSummary">
              <h3>Attestation Chain</h3>
              <div class="chain-status">
                <div class="status-indicator" :class="{ valid: chainSummary.valid, invalid: !chainSummary.valid }">
                  {{ chainSummary.valid ? '✓ Valid' : '✗ Invalid' }}
                </div>
                <div class="chain-info">
                  <div class="stat-row">
                    <span>Chain Length:</span>
                    <strong>{{ chainSummary.chain_length }}</strong>
                  </div>
                  <div class="stat-row" v-if="chainSummary.revoked_attestations > 0">
                    <span>Revoked:</span>
                    <strong class="warning">{{ chainSummary.revoked_attestations }}</strong>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div v-if="episode.artifacts && episode.artifacts.length > 0" class="artifacts-section">
            <h3>Artifacts</h3>
            <div class="artifact-list">
              <div v-for="(artifact, index) in episode.artifacts" :key="index" class="artifact-item">
                <div class="artifact-icon">📄</div>
                <div class="artifact-details">
                  <div class="artifact-name">{{ artifact.name || `Artifact ${index + 1}` }}</div>
                  <div class="artifact-meta">{{ artifact.type || 'Unknown type' }}</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Timeline Tab -->
        <div v-if="activeTab === 'timeline'" class="timeline-tab">
          <div v-if="loadingTimeline" class="loading-small">Loading timeline...</div>
          <div v-else-if="timeline.length === 0" class="empty-state">No timeline events</div>
          <div v-else class="timeline">
            <div v-for="(event, index) in timeline" :key="index" class="timeline-event" :class="event.type">
              <div class="event-marker"></div>
              <div class="event-content">
                <div class="event-header">
                  <span class="event-type">{{ formatEventType(event.type) }}</span>
                  <span class="event-time">{{ formatTime(event.timestamp) }}</span>
                </div>
                <div class="event-details">
                  <div v-if="event.type === 'execution_step'">
                    <strong>{{ event.action }}</strong>
                    <span v-if="!event.expected_path" class="deviation-badge">Deviation</span>
                    <div v-if="event.deviation" class="deviation-reason">{{ event.deviation }}</div>
                  </div>
                  <div v-else-if="event.type === 'decision_point'">
                    <strong>Decision: {{ event.chosen }}</strong>
                    <div class="decision-options">
                      Options: {{ event.options.join(', ') }}
                    </div>
                    <div class="decision-reasoning">{{ event.reasoning }}</div>
                  </div>
                  <div v-else>
                    {{ event.description }}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Deviations Tab -->
        <div v-if="activeTab === 'deviations'" class="deviations-tab">
          <div v-if="deviations">
            <div class="deviation-summary">
              <div class="summary-card">
                <div class="summary-value">{{ deviations.deviation_rate.toFixed(1) }}%</div>
                <div class="summary-label">Deviation Rate</div>
              </div>
              <div class="summary-card">
                <div class="summary-value">{{ deviations.unexpected_decisions }}</div>
                <div class="summary-label">Unexpected Decisions</div>
              </div>
            </div>

            <div v-if="Object.keys(deviations.deviation_types).length > 0" class="deviation-types">
              <h3>Deviation Types</h3>
              <div class="type-list">
                <div v-for="(count, type) in deviations.deviation_types" :key="type" class="type-item">
                  <span class="type-badge" :class="type">{{ type }}</span>
                  <span class="type-count">{{ count }}</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Logs Tab -->
        <div v-if="activeTab === 'logs'" class="logs-tab">
          <div v-if="loadingLogs" class="loading-small">Loading logs...</div>
          <div v-else-if="logs.length === 0" class="empty-state">No logs available</div>
          <div v-else class="logs-container">
            <div class="logs-table">
              <div class="log-header">
                <div class="log-col-time">Timestamp</div>
                <div class="log-col-level">Level</div>
                <div class="log-col-agent">Agent</div>
                <div class="log-col-event">Event</div>
              </div>
              <div v-for="(log, index) in logs" :key="index" class="log-row" :class="log.level.toLowerCase()">
                <div class="log-col-time">{{ formatTime(log.timestamp) }}</div>
                <div class="log-col-level">
                  <span class="level-badge" :class="log.level.toLowerCase()">{{ log.level }}</span>
                </div>
                <div class="log-col-agent">{{ log.agent }}</div>
                <div class="log-col-event">{{ log.event }}</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Chain Tab -->
        <div v-if="activeTab === 'chain'" class="chain-tab">
          <div v-if="loadingChain" class="loading-small">Loading chain...</div>
          <div v-else-if="chain.length === 0" class="empty-state">No attestation chain</div>
          <div v-else class="chain-list">
            <div v-for="(attestation, index) in chain" :key="attestation.attestation_id" class="chain-item">
              <div class="chain-index">{{ index + 1 }}</div>
              <div class="chain-content">
                <div class="chain-header">
                  <span class="chain-id">{{ attestation.attestation_id }}</span>
                  <span v-if="attestation.revoked" class="revoked-badge">Revoked</span>
                </div>
                <div class="chain-details">
                  <div class="detail-row">
                    <span>Type:</span>
                    <strong>{{ attestation.subject_type }}</strong>
                  </div>
                  <div class="detail-row">
                    <span>Agent:</span>
                    <strong>{{ attestation.agent_id }}</strong>
                  </div>
                  <div class="detail-row">
                    <span>Hash:</span>
                    <code>{{ attestation.data_hash.substring(0, 16) }}...</code>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Rating Modal -->
    <div v-if="showRatingModal" class="modal-overlay" @click="showRatingModal = false">
      <div class="modal-content" @click.stop>
        <h2>Rate Episode</h2>
        <div class="rating-form">
          <div class="form-group">
            <label>Human Rating (0-100)</label>
            <input v-model.number="ratingForm.human_rating" type="number" min="0" max="100" />
          </div>
          <div class="form-group">
            <label>Feedback</label>
            <textarea v-model="ratingForm.feedback" rows="4"></textarea>
          </div>
          <div class="modal-actions">
            <button @click="showRatingModal = false" class="btn-secondary">Cancel</button>
            <button @click="submitRating" class="btn-primary">Submit Rating</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, onMounted } from 'vue'
import { useRoute } from 'vue-router'
import axios from 'axios'

const route = useRoute()

// State
const episode = ref(null)
const timeline = ref([])
const deviations = ref(null)
const chain = ref([])
const chainSummary = ref(null)
const logs = ref([])
const loadingLogs = ref(false)
const loading = ref(false)
const loadingTimeline = ref(false)
const loadingChain = ref(false)
const error = ref(null)
const activeTab = ref('overview')
const showRatingModal = ref(false)
const ratingForm = ref({
  human_rating: 85,
  feedback: ''
})

// Computed
const tabs = computed(() => [
  { id: 'overview', label: 'Overview' },
  { id: 'timeline', label: 'Timeline', count: timeline.value.length },
  { id: 'deviations', label: 'Deviations', count: deviations.value?.deviated_steps || 0 },
  { id: 'logs', label: 'Logs', count: logs.value.length },
  { id: 'chain', label: 'Attestation Chain', count: chain.value.length }
])

// Methods
const loadEpisode = async () => {
  loading.value = true
  error.value = null
  
  try {
    const episodeId = route.params.id
    const response = await axios.get(`/api/episodes/${episodeId}`)
    episode.value = response.data
    
    // Load additional data
    await Promise.all([
      loadTimeline(),
      loadDeviations(),
      loadLogs(),
      loadChain(),
      loadChainSummary()
    ])
  } catch (err) {
    error.value = err.response?.data?.error || 'Failed to load episode'
  } finally {
    loading.value = false
  }
}

const loadTimeline = async () => {
  loadingTimeline.value = true
  try {
    const response = await axios.get(`/api/episodes/${route.params.id}/timeline`)
    timeline.value = response.data.timeline || []
  } catch (err) {
    console.error('Failed to load timeline:', err)
  } finally {
    loadingTimeline.value = false
  }
}

const loadDeviations = async () => {
  try {
    const response = await axios.get(`/api/episodes/${route.params.id}/deviations`)
    deviations.value = response.data
  } catch (err) {
    console.error('Failed to load deviations:', err)
  }
}

const loadChain = async () => {
  loadingChain.value = true
  try {
    const response = await axios.get(`/api/episodes/${route.params.id}/chain`)
    chain.value = response.data.chain || []
  } catch (err) {
    console.error('Failed to load chain:', err)
  } finally {
    loadingChain.value = false
  }
}

const loadChainSummary = async () => {
  try {
    const response = await axios.get(`/api/episodes/${route.params.id}/chain/summary`)
    chainSummary.value = response.data
  } catch (err) {
    console.error('Failed to load chain summary:', err)
  }
}

const loadLogs = async () => {
  loadingLogs.value = true
  try {
    const response = await axios.get(`/api/episodes/${route.params.id}/logs`)
    logs.value = response.data.logs || []
  } catch (err) {
    console.error('Failed to load logs:', err)
  } finally {
    loadingLogs.value = false
  }
}

const submitRating = async () => {
  try {
    await axios.post(`/api/episodes/${route.params.id}/rate`, ratingForm.value)
    showRatingModal.value = false
    await loadEpisode()
  } catch (err) {
    console.error('Failed to submit rating:', err)
    alert('Failed to submit rating')
  }
}

const calculateDuration = () => {
  if (!episode.value.started_at || !episode.value.completed_at) return 'N/A'
  
  const start = new Date(episode.value.started_at)
  const end = new Date(episode.value.completed_at)
  const diff = end - start
  
  const minutes = Math.floor(diff / 60000)
  const seconds = Math.floor((diff % 60000) / 1000)
  
  return `${minutes}m ${seconds}s`
}

const getEffectivenessClass = (score) => {
  if (score >= 80) return 'excellent'
  if (score >= 60) return 'good'
  if (score >= 40) return 'fair'
  return 'poor'
}

const formatDate = (dateString) => {
  return new Date(dateString).toLocaleString()
}

const formatTime = (dateString) => {
  return new Date(dateString).toLocaleTimeString()
}

const formatEventType = (type) => {
  return type.split('_').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')
}

// Lifecycle
onMounted(() => {
  loadEpisode()
})
</script>

