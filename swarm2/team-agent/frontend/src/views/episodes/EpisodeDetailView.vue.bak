  margin-bottom: 2rem;
}

.event-marker {
  position: absolute;
  left: -1.75rem;
  top: 0.25rem;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: #007bff;
  border: 3px solid white;
  box-shadow: 0 0 0 2px #007bff;
}

.event-content {
  background: #f8f9fa;
  padding: 1rem;
  border-radius: 4px;
}

.event-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 0.5rem;
}

.event-type {
  font-weight: 600;
  color: #007bff;
}

.event-time {
  font-size: 0.85rem;
  color: #666;
}

.deviation-badge {
  margin-left: 0.5rem;
  padding: 0.25rem 0.5rem;
  background: #fff3cd;
  color: #856404;
  border-radius: 4px;
  font-size: 0.75rem;
  font-weight: 600;
}

.deviation-reason {
  margin-top: 0.5rem;
  font-size: 0.9rem;
  color: #666;
  font-style: italic;
}

.decision-options, .decision-reasoning {
  margin-top: 0.5rem;
  font-size: 0.9rem;
  color: #666;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  padding: 2rem;
  border-radius: 8px;
  max-width: 500px;
  width: 90%;
}

.modal-content h2 {
  margin: 0 0 1.5rem 0;
}

.rating-form {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.form-group label {
  font-weight: 500;
}

.form-group input,
.form-group textarea {
  padding: 0.5rem;
  border: 1px solid #ddd;
  border-radius: 4px;
  font-size: 1rem;
}

.modal-actions {
  display: flex;
  gap: 1rem;
  justify-content: flex-end;
  margin-top: 1rem;
}

.btn-secondary {
  padding: 0.5rem 1.5rem;
  background: #6c757d;
  color: white;
  border: none;
  border-radius: 4px;
  cursor: pointer;
}

.btn-secondary:hover {
  background: #5a6268;
}

.chain-list {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.chain-item {
  display: flex;
  gap: 1rem;
  padding: 1rem;
  background: #f8f9fa;
  border-radius: 4px;
}

.chain-index {
  width: 40px;
  height: 40px;
  background: #007bff;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  flex-shrink: 0;
}

.chain-content {
  flex: 1;
}

.chain-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 0.5rem;
}

.chain-id {
  font-weight: 600;
  font-size: 0.9rem;
}

.revoked-badge {
  padding: 0.25rem 0.5rem;
  background: #f8d7da;
  color: #721c24;
  border-radius: 4px;
  font-size: 0.75rem;
  font-weight: 600;
}

.chain-details {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.detail-row {
  display: flex;
  gap: 0.5rem;
  font-size: 0.9rem;
}

.detail-row code {
  background: #e9ecef;
  padding: 0.125rem 0.5rem;
  border-radius: 4px;
  font-size: 0.85rem;
}

.empty-state {
  text-align: center;
  padding: 3rem;
  color: #666;
}

.loading-small {
  text-align: center;
  padding: 2rem;
  color: #666;
}

/* Logs Tab Styles */
.logs-container {
  overflow-x: auto;
}

.logs-table {
  min-width: 800px;
}

.log-header {
  display: grid;
  grid-template-columns: 120px 80px 150px 1fr;
  gap: 1rem;
  padding: 1rem;
  background: #f8f9fa;
  font-weight: 600;
  border-bottom: 2px solid #dee2e6;
}

.log-row {
  display: grid;
  grid-template-columns: 120px 80px 150px 1fr;
  gap: 1rem;
  padding: 1rem;
  border-bottom: 1px solid #e9ecef;
  transition: background 0.2s;
}

.log-row:hover {
  background: #f8f9fa;
}

.log-row.error {
  background: #fff5f5;
}

.log-row.warning {
  background: #fffbf0;
}

.log-col-time {
  font-family: monospace;
  font-size: 0.9rem;
}

.log-col-level {
  display: flex;
  align-items: center;
}

.level-badge {
  padding: 0.25rem 0.5rem;
  border-radius: 4px;
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
}

.level-badge.info {
  background: #d1ecf1;
  color: #0c5460;
}

.level-badge.warning {
  background: #fff3cd;
  color: #856404;
}

.level-badge.error {
  background: #f8d7da;
  color: #721c24;
}

.log-col-agent {
  font-weight: 500;
}

.log-col-event {
  color: #495057;
}
