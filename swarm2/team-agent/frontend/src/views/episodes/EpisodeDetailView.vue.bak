  color: #666;
}

.stat-row {
  display: flex;
  justify-content: space-between;
  padding: 0.5rem 0;
  border-bottom: 1px solid #e9ecef;
}

.stat-row:last-child {
  border-bottom: none;
}

.warning {
  color: #dc3545;
}

.chain-status {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.status-indicator {
  padding: 0.75rem;
